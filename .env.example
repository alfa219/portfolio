# ── Flask Core ────────────────────────────────────────────
FLASK_APP=wsgi.py
FLASK_ENV=development
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# ── Site Personalisation ─────────────────────────────────
SITE_NAME=[YOUR_NAME].iot
OWNER_NAME=[YOUR_NAME]
OWNER_EMAIL=hello@[yourdomain].dev
OWNER_LOCATION=Wates, Yogyakarta

# ── Contact form (SMTP) ──────────────────────────────────
# Gmail: aktifkan 2FA lalu buat App Password di
# https://myaccount.google.com/apppasswords — pakai itu sebagai SMTP_PASS.
# Kosongkan semua untuk menonaktifkan form (UI menampilkan email langsung).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional: penerima berbeda dari OWNER_EMAIL
CONTACT_TO=
